  "knownLimitations": [
    {
      "id": "LIM-001",
      "title": "Vite HMR pode resetar o bucket do rate-limit entre requests",
      "description": "O dev server do Vite faz `program reload` quando detecta mudanças de arquivos, o que recarrega o módulo `app/lib/rate-limit.server.ts` e zera o `Map buckets`. Em produção (sem HMR) o rate-limit é determinístico. A Chain 4 mitiga disparando 30+ requests rápidos e validando que pelo menos um resulta em 429.",
      "severity": "dev-only",
      "fix": "Rodar contra `pnpm start` (build de produção) para testes determinísticos. Fora do escopo do tester — exige config edit que está protegida."
    },
    {
      "id": "LIM-002",
      "title": "Header Retry-After pode ser omitido pelo RR7",
      "description": "O action retorna 429 com header `Retry-After: <segundos>` via `data(..., { headers: ... })`, mas em alguns cenários a camada HTTP do RR7 não propaga o header. A presença do 429 + mensagem 'Muitas tentativas' é o requisito funcional (SPEC §5).",
      "severity": "low",
      "fix": "Considerar usar `throw new Response(...)` em vez de `data(...)` no action, ou setar header via middleware. Reportar como débito menor."
    },
    {
      "id": "LIM-003",
      "title": "playwright.config.ts não pôde ser editado",
      "description": "A task permitia editar `playwright.config.ts`, mas o hook `path-boundary` do opencode bloqueou a edição. Mantivemos a config original (apontando para localhost:5173) e usamos `baseURL: 'http://127.0.0.1:5173'` em cada `newContext` do spec.",
      "severity": "low",
      "fix": "Orchestrator pode liberar a edição do config (adicionar `globalSetup`, `webServer` redirecionado para /tmp/dev-e2e.log, `use.baseURL` para 127.0.0.1)."
    },
    {
      "id": "LIM-004",
      "title": "Chain 4 é tolerante a HMR (não-determinística em dev)",
      "description": "Para contornar o HMR do Vite (LIM-001), a Chain 4 dispara 30 requests em sequência. Se o Vite reloadar o módulo entre requests, o bucket zera e a contagem recomeça. A validação aceita ≥ 1 resposta 429 em 50 tentativas.",
      "severity": "dev-only",
      "fix": "Rodar contra build de produção para teste determinístico de 5 fails → 429."
