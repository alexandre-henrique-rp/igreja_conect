          "POST /app/membros (visitante)",
          "createMembro com tipo=VISITANTE",
          "prisma.$transaction([createMembro, criarAlertaVisitante])",
          "GET /app/alertas do responsável"
        ],
        "dataFlow": "POST membros { tipo: VISITANTE } → createMembro transação → config.responsavelMembroId OU membros do config.responsavelMinisterioId → Alerta + AlertaDestinatario → listAlertas filtra por destinatario.membroId === user.id → renderiza CardAlerta com nome+telefone do visitante",
        "sprints": ["S02", "S04"],
