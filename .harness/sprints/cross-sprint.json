        "finishedInSprint": "S04",
        "e2eChain": "e2e/visitante-alerta-cross.spec.ts",
        "specRef": "US-MEM-001, RN-MEM-05",
        "atomicityRequirement": "Se alerta falha, visitante não é persistido (rollback)"
      },
      {
        "id": "CF-03",
        "name": "Config Acolhimento → Cadastrar Visitante",
        "sequence": [
          "PUT /app/config/acolhimento (ADMIN)",
          "updateConfigAcolhimento (singleton)",
          "POST /app/membros (visitante)",
          "createMembro lê config atual"
        ],
        "dataFlow": "ConfiguracaoGeral.responsavelMembroId/responsavelMinisterioId é lido no momento do cadastro do visitante, dentro da mesma transação",
        "sprints": ["S04"],
        "e2eChain": "e2e/config-acolhimento.spec.ts + e2e/visitante-alerta-cross.spec.ts",
        "specRef": "US-MEM-004, RN-MEM-05"
      },
      {
        "id": "CF-04",
        "name": "RBAC Dízimos — 3 Camadas (DEFENSE IN DEPTH)",
        "sequence": [
          "GET /app/membros/:id?tab=fidelidade",
          "Camada 1: <TabFidelidadeFinanceira> NÃO renderizado para SECRETARIO",
          "Camada 2: Loader força tab=dados (se bypass via URL)",
          "Camada 3: getDizimosByMembro lança ForbiddenError (se chamado direto)"
        ],
        "dataFlow": "user.cargo é o pivot de toda a matriz. assertCanSeeFinancials é helper canônico em rbac.server.ts (camada 3). TabsMembro filtra na render (camada 1). Loader checa explicitamente (camada 2).",
        "sprints": ["S03"],
        "e2eChain": "e2e/fidelidade-bypass.spec.ts (3 chains: UI, URL, service)",
        "specRef": "US-MEM-005, RN-MEM-03",
        "criticality": "GATE — lgpd-officer valida"
      },
      {
        "id": "CF-05",
        "name": "Trava 12 Discípulos",
        "sequence": [
          "POST /app/membros/:id/discipulador",
          "assignDisciple (camada 3)",
          "count + check < 12 + isDescendantOf"
        ],
        "dataFlow": "Cada chamada incrementa discipuladorId em um Membro. assignDisciple faz count() antes do update(). Boundary: 12 passa, 13 falha.",
        "sprints": ["S03"],
        "e2eChain": "e2e/discipulado.spec.ts (Chains 1, 2, 3)",
        "specRef": "US-MEM-002, RN-MEM-04"
      },
      {
        "id": "CF-06",
        "name": "Dashboard com RBAC Fina",
        "sequence": [
          "GET /app",
          "getDashboardData(user)",
          "count(Membro where discipuladorId=user.id) para DISCIPULADOR"
        ],
