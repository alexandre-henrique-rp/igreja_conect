// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ==========================================
// ENUMS & DICIONÁRIOS DO SISTEMA
// ==========================================

enum Cargo {
  ADMIN
  PASTOR
  SECRETARIO
  FINANCEIRO
  LIDER_MINISTERIO
}

enum TipoMembro {
  MEMBRO_ATIVO
  CONGREGADO
  VISITANTE
}

enum TipoLancamento {
  ENTRADA
  SAIDA
}

enum StatusLancamento {
  PAGO
  PENDENTE
  AGENDADO
}

enum CategoriaLancamento {
  DIZIMO
  OFERTA
  CAMPANHA
  DESPESA_OPERACIONAL
  COMPRA_ESTOQUE
  MANUTENCAO
  TRANSFERENCIA
}

enum TipoItemEstoque {
  CONSUMO
  PATRIMONIO
}

enum StatusItemPatrimonio {
  DISPONIVEL
  EM_MANUTENCAO
  BAIXADO_PERDA
}

enum StatusRequisicaoCompra {
  SOLICITADA
  APROVADA
  REJEITADA
  COMPRADA
}

// ==========================================
// MÓDULO 1: MEMBROS & USUÁRIOS
// ==========================================

model Membro {
  id            String     @id @default(uuid())
  nome          String
  tipo          TipoMembro @default(VISITANTE)
  cargo         Cargo? // Se nulo, o membro não tem acesso administrativo ao sistema
  email         String?    @unique
  senhaHash     String? // Nulo se o membro não tiver acesso ao sistema
  telefone      String?
  profissao     String?
  estadoCivil   String?
  dataConversao DateTime?
  dataBatismo   DateTime?

  // Campos pessoais adicionais (S02-T05/S02-T08 — wire-up de _dummy placeholders)
  dataNascimento   DateTime?
  sexo             String? // Validado em Zod: "Masculino" | "Feminino" | "Outro"
  status           String? // Validado em Zod: "Ativo" | "Pendente" | "Inativo"
  grupo            String? // Texto livre (placeholder — futuro: FK para Celula)
  // `discipuladorNome` evita colisão com a relation `discipulador` (FK).
  // Vínculo real continua em `discipuladorId` (aba Discipulado).
  discipuladorNome String?
  complemento      String? // Complemento de endereço (Apto, Bloco, etc.)

  // Endereço Residencial
  logradouro String?
  numero     String?
  bairro     String?
  cidade     String?
  estado     String?
  cep        String?

  // Flag que indica se o membro pode ser discipulador de outros membros
  isDiscipulador Boolean @default(false)

  // Relacionamento de Discipulado (Auto-relacionamento 1:N)
  // RN-MEM-04: 1 membro tem apenas 1 discipulador. 1 discipulador tem até 12 discípulos (validado via service)
  discipuladorId String?
  discipulador   Membro?  @relation("Discipulado", fields: [discipuladorId], references: [id], onDelete: Restrict)
  discipulos     Membro[] @relation("Discipulado")

  // Relacionamentos Eclesiásticos
  ministerios MinisterioMembro[]

  // Relacionamentos Financeiros
  dizimos Lancamento[] @relation("MembroDizimo")

  // Sessões de login (httpOnly cookie). Cascade no membro = logout automático ao excluir.
  sessions Session[]

  // Convites de acesso ao sistema (token temporário para criar senha)
  conviteTokens ConviteToken[]

  // Auditoria e Controle
  transferenciasFeitas TransferenciaCaixa[]
  estoquesRetirados    MovimentacaoEstoque[]
  alertasRecebidos     AlertaDestinatario[]

  // Relação com Configuração de Acolhimento (1 ConfiguracaoGeral pode ter 1 membro responsável)
  configuracoesAcolhimento ConfiguracaoGeral[] @relation("ResponsavelVisitante")

  // Logs de auditoria (LGPD art. 46)
  auditLogs AuditLog[] @relation("AuditLogs")

  // Relacionamentos — Cultos, Escalas, Células, Eventos
  cultosCriados      Culto[]
  escalasCriadas     Escala[]
  escalasVoluntario  EscalaVoluntario[]
  celulaLiderada     Celula?
  celulas            MembroCelula[]
  eventosResponsavel Evento[]
  eventosCriados     Evento[]           @relation("EventoCriador")

  // Upload de avatar (S3-compatible / Garage)
  avatarUploadId String?
  avatarUpload   Upload? @relation("MembroAvatar", fields: [avatarUploadId], references: [id], onDelete: SetNull)

  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  requisicoesSolicitadas RequisicaoCompra[] @relation("RequisicaoSolicitante")
  requisicoesAprovadas   RequisicaoCompra[] @relation("RequisicaoAprovador")
  requisicoesCompradas   RequisicaoCompra[] @relation("RequisicaoComprador")

  @@map("membros")
}

/**
 * Sessão de login server-side (S00-T02).
 * Cada `createSession(membroId)` insere um registro aqui; o `sid` (UUID)
 * é o valor do cookie httpOnly. Logout = `deleteSession(sid)`.
 * Sliding renewal: a cada request autenticado, `expiresAt` é atualizado
 * para `min(now + 7d, absoluteExpiresAt)`. Após `absoluteExpiresAt`,
 * o cookie é considerado expirado mesmo se o cliente ainda o enviar.
 */
model Session {
  id                String   @id @default(uuid())
  membroId          String
  expiresAt         DateTime
  absoluteExpiresAt DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  membro Membro @relation(fields: [membroId], references: [id], onDelete: Cascade)

  @@index([membroId])
  @@index([expiresAt])
  @@map("sessions")
}

/**
 * Token de convite para criação de senha (fluxo de onboarding).
 * Quando um admin cadastra um membro com cargo e email, um token
 * temporário é gerado. O membro acessa a URL pública /convite/:token
 * para criar sua senha. Token expira em 2 horas.
 */
model ConviteToken {
  id        String    @id @default(uuid())
  membroId  String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  membro Membro @relation(fields: [membroId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("convite_tokens")
}

model Ministerio {
  id               String              @id @default(uuid())
  nome             String              @unique
  descricao        String?
  status           String              @default("ATIVO")
  corDestaque      String?
  liderNome        String?
  capacidadeMaxima Int?
  diasEncontro     String?
  horarioPadrao    String?
  turnoPrincipal   String?
  membros          MinisterioMembro[]
  configGeral      ConfiguracaoGeral[] @relation("MinisterioResponsavel")
  escalas          Escala[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ministerios")
}

model MinisterioMembro {
  id           String     @id @default(uuid())
  membroId     String
  ministerioId String
  lider        Boolean    @default(false)
  membro       Membro     @relation(fields: [membroId], references: [id], onDelete: Cascade)
  ministerio   Ministerio @relation(fields: [ministerioId], references: [id], onDelete: Cascade)

  @@unique([membroId, ministerioId])
  @@map("ministerio_membros")
}

// ==========================================
// MÓDULO 2: FINANCEIRO & CAIXAS
// ==========================================

model Caixa {
  id            String  @id @default(uuid())
  nome          String  @unique // Ex: "Caixa Geral", "Caixa da Cantina"
  saldoCentavos Int     @default(0) // Armazenado em centavos para evitar erros de ponto flutuante
  ativo         Boolean @default(true) // Soft-delete / arquivamento (T01)

  lancamentos   Lancamento[]
  origemTransf  TransferenciaCaixa[] @relation("CaixaOrigem")
  destinoTransf TransferenciaCaixa[] @relation("CaixaDestino")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ativo])
  @@map("caixas")
}

model TransferenciaCaixa {
  id             String   @id @default(uuid())
  valorCentavos  Int
  caixaOrigemId  String
  caixaDestinoId String
  executadoPorId String // Usuário/Membro que realizou a transferência (RN-FIN-02)
  dataHora       DateTime @default(now())
  descricao      String?

  /**
   * UUID v4 opcional — previne double-submit/race (SEC-S07-003).
   */
  idempotencyKey String? @unique

  caixaOrigem  Caixa  @relation("CaixaOrigem", fields: [caixaOrigemId], references: [id], onDelete: Restrict)
  caixaDestino Caixa  @relation("CaixaDestino", fields: [caixaDestinoId], references: [id], onDelete: Restrict)
  executadoPor Membro @relation(fields: [executadoPorId], references: [id], onDelete: Restrict)

  @@map("transferencias_caixa")
}

model Lancamento {
  id              String              @id @default(uuid())
  tipo            TipoLancamento
  categoria       CategoriaLancamento
  status          StatusLancamento    @default(PENDENTE)
  valorCentavos   Int
  descricao       String?
  dataCompetencia DateTime            @default(now())

  caixaId String
  caixa   Caixa  @relation(fields: [caixaId], references: [id], onDelete: Restrict)

  // Se for Dízimo, o vínculo com Membro é obrigatório. Se for Oferta, pode ser anônimo (RN-FIN-05)
  membroId String?
  membro   Membro? @relation("MembroDizimo", fields: [membroId], references: [id], onDelete: SetNull)

  // RN-FIN-02: UUID que agrupa os dois lançamentos de uma transferência atômica
  transferenciaGrupoId String?

  // Comprovante anexo (NF, recibo, cupom) — 1:1 com Upload
  attachmentUploadId String?
  attachmentUpload   Upload? @relation("LancamentoAnexo", fields: [attachmentUploadId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transferenciaGrupoId])
  @@map("lancamentos")
}

// ==========================================
// MÓDULO 3: ESTOQUE & MANUTENÇÃO
// ==========================================

model ItemEstoque {
  id               String          @id @default(uuid())
  nome             String
  descricao        String?
  tipo             TipoItemEstoque @default(CONSUMO)
  quantidade       Int             @default(0) // Para consumo, incrementa/decrementa. Para patrimônio, geralmente é 1 por unidade física
  quantidadeMinima Int             @default(5) // Quantidade mínima para alerta de estoque baixo

  // Campos específicos de Bens Patrimoniais
  numeroSerie       String?               @unique
  statusPatrimonio  StatusItemPatrimonio? @default(DISPONIVEL)
  localizacaoFisica String?

  // Soft-delete: false = arquivado (não aparece nas listas padrão)
  ativo Boolean @default(true)

  movimentacoes MovimentacaoEstoque[]
  manutencoes   ManutencaoAtivo[]

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  requisicaoCompras RequisicaoCompra[]

  @@index([tipo, ativo])
  @@map("itens_estoque")
}

model MovimentacaoEstoque {
  id            String  @id @default(uuid())
  itemEstoqueId String
  quantidade    Int // Positivo para Entrada, Negativo para Saída
  justificativa String? // Ex: "Retirada para o culto infantil", "Doação recebida"

  // RN-EST-02: Apenas ADMIN e SECRETÁRIO autorizam, registrando a pessoa física que retirou
  autorizadoPorId String
  nomeRetirante   String // Nome textual da pessoa que pegou o item no almoxarifado

  itemEstoque   ItemEstoque @relation(fields: [itemEstoqueId], references: [id], onDelete: Restrict)
  autorizadoPor Membro      @relation(fields: [autorizadoPorId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@map("movimentacoes_estoque")
}

model ManutencaoAtivo {
  id                  String    @id @default(uuid())
  itemEstoqueId       String
  assistenciaTecnica  String // Razão Social / Nome da Assistência (RN-EST-03)
  enderecoAssistencia String
  numeroOs            String? // Número da Ordem de Serviço
  dataEnvio           DateTime  @default(now())
  prazoTermino        DateTime? // Opcional. Se nulo, ativa a trigger do Cron de Alertas (RN-EST-04)
  dataRetorno         DateTime?

  // Caso dê Perda Total (RN-EST-05)
  foiPerdaTotal   Boolean @default(false)
  urlLaudoTecnico String? // Link do arquivo armazenado no MinIO
  motivo          String? // Motivo da baixa por perda (RN-EST-05)

  itemEstoque ItemEstoque @relation(fields: [itemEstoqueId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("manutencoes_ativo")
}

model RequisicaoCompra {
  id            String                 @id @default(uuid())
  itemEstoqueId String? // Se null, é para um item novo ainda não cadastrado
  nomeItem      String // Nome do item solicitado (mesmo se itemEstoqueId for null)
  quantidade    Int
  justificativa String?
  status        StatusRequisicaoCompra @default(SOLICITADA)
  valorCentavos Int? // Preenchido quando comprado
  observacao    String? // Observação do aprovador ou comprador

  solicitadoPorId String
  aprovadoPorId   String?
  compradoPorId   String?

  // Vínculo opcional com lançamento financeiro quando comprada
  lancamentoId String?

  itemEstoque   ItemEstoque? @relation(fields: [itemEstoqueId], references: [id], onDelete: SetNull)
  solicitadoPor Membro       @relation("RequisicaoSolicitante", fields: [solicitadoPorId], references: [id], onDelete: Restrict)
  aprovadoPor   Membro?      @relation("RequisicaoAprovador", fields: [aprovadoPorId], references: [id], onDelete: SetNull)
  compradoPor   Membro?      @relation("RequisicaoComprador", fields: [compradoPorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([solicitadoPorId])
  @@map("requisicoes_compra")
}

// ==========================================
// MÓDULO 4: CULTOS
// ==========================================

enum TipoCulto {
  PRESENCIAL
  HIBRIDO
  ONLINE
}

enum StatusCulto {
  AGENDADO
  CONFIRMADO
  REALIZADO
  CANCELADO
}

model Culto {
  id          String      @id @default(uuid())
  titulo      String
  descricao   String?
  tipo        TipoCulto   @default(PRESENCIAL)
  status      StatusCulto @default(AGENDADO)
  data        DateTime
  horario     String
  local       String?
  preletor    String?
  createdById String?
  createdBy   Membro?     @relation(fields: [createdById], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("cultos")
}

// ==========================================
// MÓDULO 5: ESCALAS
// ==========================================

enum StatusEscala {
  PENDENTE
  CONFIRMADA
  REALIZADA
  CANCELADA
}

model Escala {
  id           String             @id @default(uuid())
  ministerioId String
  ministerio   Ministerio         @relation(fields: [ministerioId], references: [id], onDelete: Cascade)
  titulo       String
  data         DateTime
  observacao   String?
  status       StatusEscala       @default(PENDENTE)
  createdById  String?
  createdBy    Membro?            @relation(fields: [createdById], references: [id])
  voluntarios  EscalaVoluntario[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([ministerioId])
  @@map("escalas")
}

model EscalaVoluntario {
  id         String  @id @default(uuid())
  escalaId   String
  membroId   String
  funcao     String
  status     String  @default("CONFIRMADO")
  observacao String?

  escala Escala @relation(fields: [escalaId], references: [id], onDelete: Cascade)
  membro Membro @relation(fields: [membroId], references: [id], onDelete: Restrict)

  @@unique([escalaId, membroId, funcao])
  @@map("escala_voluntarios")
}

// ==========================================
// MÓDULO 6: CÉLULAS
// ==========================================

model Celula {
  id        String         @id @default(uuid())
  nome      String         @unique
  descricao String?
  liderId   String?        @unique
  lider     Membro?        @relation(fields: [liderId], references: [id], onDelete: SetNull)
  endereco  String?
  diaSemana String?
  horario   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  membros   MembroCelula[]

  @@map("celulas")
}

model MembroCelula {
  id       String @id @default(uuid())
  celulaId String
  membroId String

  celula Celula @relation(fields: [celulaId], references: [id], onDelete: Cascade)
  membro Membro @relation(fields: [membroId], references: [id], onDelete: Cascade)

  @@unique([membroId, celulaId])
  @@map("membro_celulas")
}

// ==========================================
// MÓDULO 7: EVENTOS
// ==========================================

enum TipoEvento {
  ESPECIAL
  CAMPANHA
  CONFRATERNIZACAO
  RETIRO
  OUTRO
}

enum StatusEvento {
  RASCUNHO
  PUBLICADO
  REALIZADO
  CANCELADO
}

model Evento {
  id            String       @id @default(uuid())
  titulo        String
  descricao     String?
  tipo          TipoEvento   @default(ESPECIAL)
  status        StatusEvento @default(RASCUNHO)
  dataInicio    DateTime
  dataFim       DateTime?
  local         String?
  responsavelId String?
  responsavel   Membro?      @relation(fields: [responsavelId], references: [id], onDelete: SetNull)
  createdById   String?
  createdBy     Membro?      @relation("EventoCriador", fields: [createdById], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("eventos")
}

// ==========================================
// CENTRAL DE ALERTAS & CONFIGURAÇÕES GERAIS
// ==========================================

model Alerta {
  id            String               @id @default(uuid())
  titulo        String
  mensagem      String
  resolvido     Boolean              @default(false)
  destinatarios AlertaDestinatario[]

  createdAt DateTime @default(now())

  @@map("alertas")
}

model AlertaDestinatario {
  id        String  @id @default(uuid())
  alertaId  String
  membroId  String // ID do usuário administrativo que precisa ver o alerta
  lido      Boolean @default(false)
  resolvido Boolean @default(false) // RN-ALERTA-01: estado por destinatário

  alerta Alerta @relation(fields: [alertaId], references: [id], onDelete: Cascade)
  membro Membro @relation(fields: [membroId], references: [id], onDelete: Cascade)

  @@unique([alertaId, membroId])
  @@map("alerta_destinatarios")
}

model ConfiguracaoGeral {
  id                       String  @id @default(uuid())
  // RN-MEM-05: Configuração de acolhimento de visitantes
  responsavelVisitanteTipo String // "MEMBRO" ou "MINISTERIO"
  responsavelMembroId      String?
  responsavelMinisterioId  String?

  responsavelMembro     Membro?     @relation("ResponsavelVisitante", fields: [responsavelMembroId], references: [id])
  responsavelMinisterio Ministerio? @relation("MinisterioResponsavel", fields: [responsavelMinisterioId], references: [id])

  @@map("configuracoes_gerais")
}

// ==========================================
// MÓDULO 8: STORAGE / UPLOADS (Garage S3-compat)
// ==========================================
//
// Segue `training/object-storage-standard.md` (perfil "Completo" adaptado
// para SQLite + Garage). Pipeline: Cliente → POST /api/uploads → bucket
// staging → worker (magic bytes → ClamAV → variants lg/md/sm) → bucket
// final → delete staging → status READY. Soft delete LGPD.

/// Metadata de um upload (imagem/vídeo/áudio/documento).
/// Storage real fica no Garage; aqui guardamos só o tracking.
model Upload {
  id          String  @id @default(uuid())
  userId      String? // Quem subiu (admin que fez upload)
  kind        String // 'image' | 'video' | 'audio' | 'document'
  contextId   String? // ID do objeto relacionado (membroId, etc)
  contextType String? // 'membro.avatar' | 'membro.document' | etc
  isPublic    Boolean @default(false)

  // Identificação do arquivo
  originalFilename String
  declaredMime     String // Content-Type enviado pelo client (NÃO confiar)
  detectedMime     String? // Magic bytes (verdade)
  sizeBytes        Int
  sha256           String? // Hash do original (quando worker processa)
  ext              String? // Extensão inferida do MIME detectado

  // Storage (S3-compatible / Garage)
  bucket           String // Bucket final (ex: "igreja-conect-images")
  storageKeyPrefix String // "<contextId>/<uploadId>" (sem extensão)

  // Variants (JSON string array; SQLite não tem TEXT[])
  // Ex: '["lg","md","sm"]' para image; NULL para document
  variants String?

  // Status: PROCESSING → SCANNING → TRANSCODING → READY | REJECTED | FAILED
  status           String  @default("PROCESSING")
  rejectionReason  String? // 'virus_detected' | 'mime_mismatch' | 'too_large' | etc
  rejectionDetails String? // JSON string com detalhes do erro

  // Audit / Lifecycle
  createdAt      DateTime  @default(now())
  processedAt    DateTime?
  failedAt       DateTime?
  deletedAt      DateTime? // Soft delete (LGPD art. 18, VI)
  retentionUntil DateTime? // Hard delete agendado
  isPii          Boolean   @default(false)

  // Relations
  membrosAvatar    Membro[]     @relation("MembroAvatar")
  lancamentosAnexo Lancamento[] @relation("LancamentoAnexo")

  @@index([userId])
  @@index([contextType, contextId])
  @@index([status])
  @@index([deletedAt])
  @@index([sha256, kind])
  @@map("uploads")
}

/// Log de auditoria LGPD (art. 46 — controle de acesso).
/// Eventos: login, logout, membro.create, membro.update, etc.
model AuditLog {
  id        String   @id @default(uuid())
  membroId  String? // alvo da ação (ex: membro sendo editado)
  event     String
  actorId   String? // quem executou
  actorRole String?
  details   String? // JSON string
  ipHash    String? // SHA-256 do IP (LGPD)
  userAgent String?
  createdAt DateTime @default(now())

  membro Membro? @relation("AuditLogs", fields: [membroId], references: [id], onDelete: Cascade)

  @@index([membroId])
  @@index([event, createdAt])
  @@map("audit_log")
}

/// Fila assíncrona SQLite-based (sem Redis/BullMQ).
/// Worker polling loop processa jobs em ordem FIFO por queue.
/// `payload` é JSON string com dados específicos do job.
model Job {
  id          String    @id @default(uuid())
  queue       String // 'media.process' | 'media.cleanup' | etc
  payload     String // JSON string
  status      String    @default("PENDING") // PENDING | RUNNING | DONE | FAILED | DEAD
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  lastError   String?
  scheduledAt DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([queue, status, scheduledAt])
  @@map("jobs")
}
