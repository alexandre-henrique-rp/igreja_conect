          "data": {
            "caixaOrigem": "{context.caixaOrigem.id}",
            "caixaDestino": "{context.caixaDestino.id}",
            "valor": "100,00",
            "descricao": "Transferência E2E Chain 1"
          },
          "expected": { "pass": true }
        },
        {
          "step": 5,
          "name": "submeter-transferencia",
          "action": "submit",
          "path": "/app/financeiro/transferencias/nova",
          "data": {
            "origemId": "{context.caixaOrigem.id}",
            "destinoId": "{context.caixaDestino.id}",
            "valorCentavos": 10000,
            "descricao": "Transferência E2E Chain 1"
          },
          "expected": { "status": 302, "redirect": "/app/financeiro" }
        },
        {
          "step": 6,
          "name": "verificar-saldo-origem-decrementado",
          "action": "assert",
          "path": "/app/financeiro/caixas/{context.caixaOrigem.id}",
          "data": { "contains": "R$ 0,00" },
          "expected": { "pass": true }
        },
        {
          "step": 7,
          "name": "verificar-saldo-destino-incrementado",
          "action": "assert",
          "path": "/app/financeiro/caixas/{context.caixaDestino.id}",
          "data": { "contains": "R$ 100,00" },
          "expected": { "pass": true }
        },
        {
          "step": 8,
          "name": "verificar-lancamentos-mesmo-grupo",
          "action": "api",
          "path": "/api/db/lancamentos",
          "data": { "transferenciaGrupoId": "{context.transferenciaGrupoId}" },
          "expected": { "count": 2, "tipoSAIDA": "SAIDA", "tipoENTRADA": "ENTRADA" },
          "assertions": [
            { "field": "length", "operator": "equals", "value": 2 },
            { "field": "[0].categoria", "operator": "equals", "value": "TRANSFERENCIA" },
            { "field": "[1].categoria", "operator": "equals", "value": "TRANSFERENCIA" }
          ]
        },
        {
          "step": 9,
          "name": "cleanup",
          "action": "api",
          "path": "/api/db/cleanup",
          "data": {
            "caixaOrigemId": "{context.caixaOrigem.id}",
            "caixaDestinoId": "{context.caixaDestino.id}"
          },
          "expected": { "status": 200 },
          "cleanup": true
