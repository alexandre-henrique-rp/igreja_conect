          "action": "api",
          "path": "/api/db/setup",
          "data": {
            "caixaOrigem": { "nome": "Caixa Origem E2E", "saldoCentavos": 10000 },
            "caixaDestino": { "nome": "Caixa Destino E2E", "saldoCentavos": 0 }
          },
          "expected": { "status": 200 },
          "records": ["caixaOrigem.id", "caixaDestino.id"]
        },
        {
          "step": 2,
          "name": "login-admin",
          "action": "login",
          "path": "/app/login",
          "data": { "email": "admin@igreja.local", "cargo": "ADMIN" },
          "expected": { "status": 200 }
        },
        {
          "step": 3,
          "name": "navegar-nova-transferencia",
          "action": "navigate",
          "path": "/app/financeiro/transferencias/nova",
          "expected": { "status": 200 }
        },
        {
          "step": 4,
          "name": "preencher-formulario",
          "action": "fill",
