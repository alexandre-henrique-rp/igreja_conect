{
  "$schema": "../templates/E2E-CHAIN-TEMPLATE.json",
  "sprint": "S08",
  "module": "fidelidade-financeira",
  "rules": ["RN-MEM-03"],
  "chains": [
    {
      "id": "E2E-S08-FIN-001",
      "name": "ADMIN/PASTOR/FINANCEIRO veem dizimos do membro",
      "description": "Valida que perfis autorizados veem dados financeiros via TabFidelidadeFinanceira (camada UI)",
      "userStory": "US-FIN-006 (Fidelidade)",
      "priority": "critical",
      "dataSource": "fresh",
      "sequence": [
        {
          "step": 1,
          "name": "login-admin",
          "action": "POST",
          "path": "/login",
          "payload": { "email": "admin@igreja.local", "senha": "admin123" },
          "expectedStatus": 302,
          "records": [{ "field": "set-cookie", "pattern": "__session=([^;]+)" }],
          "intoContext": "auth.admin"
        },
        {
          "step": 2,
          "name": "get-membro-detail",
          "action": "GET",
          "path": "/app/membros/{context.membro.targetId}",
          "expectedStatus": 200,
          "assertions": [
            "body includes data-testid=\"tab-fidelidade\"",
            "body includes ResumoFinanceiro",
            "body does NOT include sem permissao"
          ]
        },
        {
          "step": 3,
          "name": "verify-finance-tab-active",
          "action": "GET",
          "path": "/app/membros/{context.membro.targetId}?tab=fidelidade",
          "expectedStatus": 200,
          "assertions": [
            "body includes Dizimos",
            "body includes totalCentavos"
          ]
        }
      ],
      "cleanup": {
        "path": "/logout",
        "method": "POST"
      }
    },
    {
      "id": "E2E-S08-FIN-002",
      "name": "SECRETARIO ve mensagem sem permissao",
      "description": "SECRETARIO pode lancar mas NAO pode ver dizimos — RN-MEM-03 camada 3",
      "userStory": "US-FIN-008 (RBAC)",
      "priority": "critical",
      "dataSource": "fresh",
      "sequence": [
        {
          "step": 1,
          "name": "login-secretario",
          "action": "POST",
          "path": "/login",
          "payload": { "email": "secretario@igreja.local", "senha": "sec12345" },
          "expectedStatus": 302,
          "records": [{ "field": "set-cookie", "pattern": "__session=([^;]+)" }],
          "intoContext": "auth.secretario"
        },
        {
          "step": 2,
          "name": "get-membro-detail-secretario",
          "action": "GET",
          "path": "/app/membros/{context.membro.targetId}",
          "expectedStatus": 200,
          "assertions": [
            "body does NOT contain data-testid=\"tab-fidelidade\"",
            "OR body contains sem permissao",
            "body does NOT contain Dizimos"
          ]
        },
        {
          "step": 3,
          "name": "bypass-url-blocked",
          "action": "GET",
          "path": "/app/membros/{context.membro.targetId}?tab=fidelidade",
          "expectedStatus": 200,
          "assertions": [
            "body does NOT contain Dizimos",
            "body does NOT contain totalCentavos"
          ]
        }
      ],
      "cleanup": {
        "path": "/logout",
        "method": "POST"
      }
    },
    {
      "id": "E2E-S08-FIN-003",
      "name": "DISCIPULADOR ve mensagem sem permissao",
      "description": "DISCIPULADOR NAO ve dados financeiros — RN-MEM-03",
      "userStory": "US-FIN-008 (RBAC)",
      "priority": "critical",
      "dataSource": "fresh",
      "sequence": [
        {
          "step": 1,
          "name": "login-discipulador",
          "action": "POST",
          "path": "/login",
          "payload": { "email": "discipulador@igreja.local", "senha": "disc12345" },
          "expectedStatus": 302,
          "records": [{ "field": "set-cookie", "pattern": "__session=([^;]+)" }],
          "intoContext": "auth.discipulador"
        },
        {
          "step": 2,
          "name": "get-membro-detail-discipulador",
          "action": "GET",
          "path": "/app/membros/{context.membro.targetId}",
          "expectedStatus": 200,
          "assertions": [
            "body does NOT contain data-testid=\"tab-fidelidade\"",
            "OR body contains sem permissao",
            "body does NOT contain Dizimos"
          ]
        }
      ],
      "cleanup": {
        "path": "/logout",
        "method": "POST"
      }
    }
  ]
}
